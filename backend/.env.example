# ── Kuroshiba backend config ───────────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real `.env`.

# Trading mode: sim | paper | live
#   sim   = backtest / offline simulation (no broker connection)
#   paper = Alpaca paper trading (virtual funds)  ← default, safe
#   live  = Alpaca live trading (REAL money)
TRADING_MODE=paper

# Live trading is a deliberate two-key safety gate (spec §2-2, §2-3, §3).
# Even with valid live keys, live orders are DISABLED unless this is true.
LIVE_TRADING_ENABLED=false

# ── Alpaca API keys ─────────────────────────────────────────────────────────
# Generate from the Alpaca dashboard.
# SECURITY: issue keys with TRADING permission only. Funding/withdrawals are
# done on Alpaca's own site, never via this app (spec §2-4, §11).

# Paper keys (https://paper-api.alpaca.markets)
ALPACA_PAPER_KEY_ID=
ALPACA_PAPER_SECRET_KEY=

# Live keys (https://api.alpaca.markets) — leave blank until Phase 4
ALPACA_LIVE_KEY_ID=
ALPACA_LIVE_SECRET_KEY=

# ── Storage ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/kuroshiba.sqlite

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
